# Backend API (default: http://localhost:8000)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Database Configuration (for future database integration)
# DATABASE_URL=postgresql://user:password@localhost:5432/edgelearn

# Authentication (for future OAuth integration)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# Analytics (for future analytics integration)
# NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# Feature Flags
# NEXT_PUBLIC_ENABLE_DARK_MODE=true
# NEXT_PUBLIC_ENABLE_SOCIAL_FEATURES=true
